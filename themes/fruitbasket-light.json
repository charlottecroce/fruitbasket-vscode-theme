  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#4C7A4E"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#3F6841"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#B81C69"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#2C56AE"
      }
    },
    {
      "name": "Classes, Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution"
      ],
      "settings": {
        "foreground": "#96650A"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "entity.name.variable"
      ],
      "settings": {
        "foreground": "#40313A"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "variable.other.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#BE2E6B"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#BE2E6B"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#6E5A64"
      }
    },
    {
      "name": "Brackets",
      "scope": [
        "meta.brace.square",
        "punctuation.definition.bracket"
      ],
      "settings": {
        "foreground": "#1B7A86"
      }
    },
    {
      "name": "Braces",
      "scope": [
        "meta.brace.curly",
        "punctuation.definition.block"
      ],
      "settings": {
        "foreground": "#96650A"
      }
    },
    {
      "name": "Parentheses",
      "scope": [
        "meta.brace.round",
        "punctuation.definition.parameters",
        "punctuation.definition.group"
      ],
      "settings": {
        "foreground": "#B81C69"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#B81C69"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#96650A"
      }
    },
    {
      "name": "Markup Headings",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#B81C69",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#40313A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#40313A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup Links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#2C56AE"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#1B7A86"
      }
    },
    {
      "name": "Escape Characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#1B7A86"
      }
    },
    {
      "name": "JSON Property Names",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#B81C69"
      }
    },
    {
      "name": "JSON String",
      "scope": [
        "string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#3F6841"
      }
    },
    {
      "name": "CSS Properties",
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#B81C69"
      }
    },
    {
      "name": "CSS Property Values",
      "scope": [
        "support.constant.property-value.css"
      ],
      "settings": {
        "foreground": "#3F6841"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#B81C69"
      }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag.html"
      ],
      "settings": {
        "foreground": "#B81C69"
      }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#96650A"
      }
    },
    {
      "name": "JavaScript Variables",
      "scope": [
        "variable.other.readwrite.js",
        "variable.other.object.js"
      ],
      "settings": {
        "foreground": "#40313A"
      }
    },
    {
      "name": "TypeScript Types",
      "scope": [
        "support.type.primitive.ts",
        "support.type.builtin.ts"
      ],
      "settings": {
        "foreground": "#96650A"
      }
    },
    {
      "name": "Python Function Parameter",
      "scope": [
        "variable.parameter.function.language.python"
      ],
      "settings": {
        "foreground": "#96650A"
      }
    },
    {
      "name": "Python Function Call",
      "scope": [
        "meta.function-call.python"
      ],
      "settings": {
        "foreground": "#2C56AE"
      }
    },
    {
      "name": "Markdown URL",
      "scope": [
        "markup.underline.link.markdown"
      ],
      "settings": {
        "foreground": "#2C56AE"
      }
    },
    {
      "name": "Markdown Headings",
      "scope": [
        "markup.heading.markdown"
      ],
      "settings": {
        "foreground": "#B81C69"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": [
        "markup.bold.markdown"
      ],
      "settings": {
        "foreground": "#B81C69",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": [
        "markup.italic.markdown"
      ],
      "settings": {
        "foreground": "#B81C69",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw.markdown"
      ],
      "settings": {
        "foreground": "#3F6841"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "enumMember": {
      "foreground": "#1B7A86"
    },
    "variable.constant": {
      "foreground": "#BE2E6B"
    },
    "variable.defaultLibrary": {
      "foreground": "#96650A"
    }
  }
}